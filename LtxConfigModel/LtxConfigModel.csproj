<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net6.0;net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <Title>Phoenix Tools S.T.A.L.K.E.R. .ltx config file model</Title>
    <Version>1.0.0</Version>
    <Company>Vadim Kutin</Company>
    <Description>Provides a model and parser for working with .ltx configuration files of the S.T.A.L.K.E.R. game.</Description>
    <Copyright>Copyright 2026</Copyright>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageTags>Stalker;S.T.A.L.K.E.R.;ltx;configuration file;</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>True</PackageRequireLicenseAcceptance>
    <PackageProjectUrl>https://github.com/Samael7777/LtxConfigModel</PackageProjectUrl>
    <RepositoryUrl>https://github.com/Samael7777/LtxConfigModel</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../README.md" Link="README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

</Project>
